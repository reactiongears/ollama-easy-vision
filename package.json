    "ollama",
    "vision",
    "mcp",
    "image",
    "qwen",
    "qwen3-vl"
  ],
  "author": "reactiongears",
  "license": "AGPL-3.0",
  "devDependencies": {
    "@opencode-ai/plugin": "^1.1.25",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reactiongears/ollama-easy-vision"
  }
